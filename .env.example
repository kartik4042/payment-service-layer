# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=payment_orchestration
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Server Configuration
SERVER_PORT=8080

# Zipkin Tracing
ZIPKIN_URL=http://localhost:9411
ZIPKIN_ENABLED=true
TRACE_SAMPLE_RATE=1.0

# Provider A Configuration
PROVIDER_A_URL=http://localhost:8081
PROVIDER_A_API_KEY=your-provider-a-api-key

# Provider B Configuration
PROVIDER_B_URL=http://localhost:8082
PROVIDER_B_API_KEY=your-provider-b-api-key

# Webhook Configuration
WEBHOOK_SECRET=your-webhook-secret-key-change-in-production

# Environment
SPRING_PROFILES_ACTIVE=dev